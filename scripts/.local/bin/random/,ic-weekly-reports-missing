#!/bin/sh
# Generate a message asking folks to fill in their weekly report

set -e

pages="$(confluence children "$IC_WEEKLY_REPORTS_CONFLUENCE_PAGE" --format json)"

title="$(echo "$pages" | jq -r '.children[-1].title')"
url="$(echo "$pages" | jq -r '.children[-1].url')"
id="$(echo "$pages" | jq -r '.children[-1].id')"

prompt="Construct a short markdown message nudging folks to submit their weekly updates.

Required structure:

<output>
[$title]($url)

A short (max 7 words) professional blunt nudge line.

A comma-separated list of names of people who have NOT filled in the weekly report, based on the page content provided on stdin. All on one line.
</output>

Output only the final message. No preamble, no code fences, no commentary."

confluence read "$id" | fin -ui quiet "$prompt" | tee /dev/stderr | mdclip
