#!/bin/sh
# Show names of folks who have not filled in the weekly report

set -e

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

pages="$(confluence children $IC_WEEKLY_REPORTS_CONFLUENCE_PAGE --format json)"

# Print name
title="$(echo "$pages" | jq -r '.children[-1].title')"
url="$(echo "$pages" | jq -r '.children[-1].url')"
id="$(echo "$pages" | jq -r '.children[-1].id')"

echo "$title"
confluence read "$id" |
    esa +notools -- "Who all has not filled in the weekly reports? " \
        "Output just the names as a list with \- prefix. The output should contain nothing else." > "$tmp"

printf 'Submit your weekly updates\n[%s](%s)\n\nMissing:\n%s\n' "$title" "$url" "$(cat "$tmp")" | glow
printf 'Submit your weekly updates\n[%s](%s)\n\nMissing:\n%s\n' "$title" "$url" "$(cat "$tmp")" | mdclip

printf "\n\nPress any key to open the webpage"
read -r REPLY # just waiting for a keypress
open "$url"
