#!/bin/zsh

set -e

me="meain"
since="$(date -v-1m +%Y-%m-%d 2>/dev/null || date -d '1 month ago' +%Y-%m-%d)"
fields="number,url,title,author,repository,createdAt"

if [[ -t 1 ]]; then
    dim=$'\033[90m'; reset=$'\033[0m'
    hdr=$(tput setaf 3); hdr_reset=$(tput sgr0)
else
    dim=""; reset=""; hdr=""; hdr_reset=""
fi

search_prs() {
    case "$1" in
    review)
        gh search prs --review-requested "$me" --state open --updated ">$since" --json $fields --limit 100 -- "draft:false -author:$me -review:approved"
        ;;
    approved)
        gh search prs --author "$me" --state open --review approved --json $fields --limit 100
        ;;
    pending)
        gh search prs --author "$me" --state open --json $fields --limit 100 -- "-review:approved"
        ;;
    esac
}

# $1 = json file, $2 = "term" (short #N, dim ANSI when stdout is a tty) or "md" (plain markdown with [#N](url) links)
render() {
    jq -r --arg mode "$2" --arg dim "$dim" --arg reset "$reset" '
        def age:
          ((now - (.createdAt | fromdateiso8601)) / 86400 | floor) as $d
          | if   $d >= 30 then "\($d / 30 | floor)mo"
            elif $d >=  7 then "\($d /  7 | floor)w"
            elif $d >=  1 then "\($d)d"
            else "<1d"
            end;
        def header(name):
          if $mode == "term" then "# \(name)" else "## \(name)" end;
        def line:
          if $mode == "term" then
            "- #\(.number) \(.title) \($dim)@\(.author.login)\($reset) \($dim)(\(age))\($reset)"
          else
            "- [#\(.number)](\(.url)) \(.title) @\(.author.login) (\(age))"
          end;
        group_by(.repository.nameWithOwner)
        | sort_by(.[0].repository.nameWithOwner)
        | .[]
        | header(.[0].repository.nameWithOwner),
          (.[] | line)
    ' "$1"
}

has_results() {
    [[ -s $1 ]] && [[ $(jq 'length' "$1") -gt 0 ]]
}

run_command() {
    action="$1"
    kind="$2"
    tempfile=$(mktemp)
    search_prs "$kind" >"$tempfile"

    if has_results "$tempfile"; then
        render "$tempfile" term
        render "$tempfile" md | pbcopy
        ,linkify

        if [[ $action != show ]]; then
            jq -r '.[].url' "$tempfile" | xargs open
        fi
    else
        echo "No PRs found"
    fi
    rm -f "$tempfile"
}

case "$1" in
r | review)
    run_command "${2:-show}" review
    ;;
a | approved)
    run_command "${2:-show}" approved
    ;;
p | pending)
    run_command "${2:-show}" pending
    ;;
h | help | --help | -h)
    echo "Use one of:"
    echo "- [a]pproved: Approved PRs"
    echo "- [p]ending: Pending approvals on others"
    echo "- [r]eview: Review pending on me"
    exit 0
    ;;
*) # Show all with color headings for each section
    tmp_a=$(mktemp); tmp_p=$(mktemp); tmp_r=$(mktemp)
    (search_prs approved >"$tmp_a") &
    (search_prs pending  >"$tmp_p") &
    (search_prs review   >"$tmp_r") &
    wait

    section() {
        if has_results "$1"; then
            render "$1" term
        else
            echo "No PRs found"
        fi
    }

    printf "%sApproved[a]%s\n" "$hdr" "$hdr_reset"
    section "$tmp_a"
    printf "\n%sPending Approval[p]%s\n" "$hdr" "$hdr_reset"
    section "$tmp_p"
    printf "\n%sTo Review[r]%s\n" "$hdr" "$hdr_reset"
    section "$tmp_r"

    rm -f "$tmp_a" "$tmp_p" "$tmp_r"
    ;;
esac
