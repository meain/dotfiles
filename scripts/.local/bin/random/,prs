#!/bin/zsh

set -e

me="meain"
since="$(date -v-1m +%Y-%m-%d 2>/dev/null || date -d '1 month ago' +%Y-%m-%d)"

search_prs() {
    kind="$1"
    case "$kind" in
    review)
        set -- --review-requested "$me" --state open --updated ">$since" --json number,url,title,author,repository --limit 100 -- "draft:false -author:$me -review:approved"
        ;;
    approved)
        set -- --author "$me" --state open --review approved --json number,url,title,author,repository --limit 100
        ;;
    pending)
        set -- --author "$me" --state open --json number,url,title,author,repository --limit 100 -- "-review:approved"
        ;;
    esac
    gh search prs "$@" |
        jq -r 'group_by(.repository.nameWithOwner)
            | sort_by(.[0].repository.nameWithOwner)
            | .[]
            | "## \(.[0].repository.nameWithOwner)",
              (.[] | "- [#\(.number)](\(.url)) \(.title) @\(.author.login)")'
}

run_command() {
    action="$1"
    kind="$2"
    tempfile=$(mktemp)
    search_prs "$kind" >"$tempfile"

    if [[ -s $tempfile ]]; then
        case "$action" in
        show)
            cat "$tempfile" | sed 's|##|#|' | sed 's|\[\(#.*\)\](.*)\(.*\)|\1\2|' | sed $'s|@\\([^ ]*\\)|\033[90m@\\1\033[0m|'
            sed 's|\ *-|-|' <"$tempfile" | pbcopy
            ,linkify
            ;;
        *)
            cat "$tempfile" | sed 's|##|#|' | sed 's|\[\(#.*\)\](.*)\(.*\)|\1\2|' | sed $'s|@\\([^ ]*\\)|\033[90m@\\1\033[0m|'
            sed 's|\ *-|-|' <"$tempfile" | pbcopy
            ,linkify

            cat "$tempfile" | grep -E '^\s*-' | cut -d'(' -f2 | cut -d')' -f1 | xargs open
            ;;
        esac
    else
        echo "No PRs found"
    fi
    rm -f "$tempfile"
}

case "$1" in
r | review)
    run_command "${2:-show}" review
    ;;
a | approved)
    run_command "${2:-show}" approved
    ;;
p | pending)
    run_command "${2:-show}" pending
    ;;
h | help | --help | -h)
    echo "Use one of:"
    echo "- [a]pproved: Approved PRs"
    echo "- [p]ending: Pending approvals on others"
    echo "- [r]eview: Review pending on me"
    exit 0
    ;;
*) # Show all with color headings for each section
    tmp_a=$(mktemp); tmp_p=$(mktemp); tmp_r=$(mktemp)
    (search_prs approved >"$tmp_a") &
    (search_prs pending >"$tmp_p") &
    (search_prs review >"$tmp_r") &
    wait

    fmt() {
        if [[ -s $1 ]]; then
            cat "$1" | sed 's|##|#|' | sed 's|\[\(#.*\)\](.*)\(.*\)|\1\2|' | sed $'s|@\\([^ ]*\\)|\033[90m@\\1\033[0m|'
        else
            echo "No PRs found"
        fi
    }

    printf "%sApproved[a]%s\n" "$(tput setaf 3)" "$(tput sgr0)"
    fmt "$tmp_a"
    printf "\n%sPending Approval[p]%s\n" "$(tput setaf 3)" "$(tput sgr0)"
    fmt "$tmp_p"
    printf "\n%sTo Review[r]%s\n" "$(tput setaf 3)" "$(tput sgr0)"
    fmt "$tmp_r"

    rm -f "$tmp_a" "$tmp_p" "$tmp_r"
    ;;
esac
