#!/usr/bin/env bash
# bash for read -ei (editable pre-filled input)

# Plaintext bookmark manager (markdown format)
# Usage: ,bm [add|show|list|open|remove] [url]

set -e

BM_FILE="${BM_FILE:-$HOME/.local/share/bookmarks.md}"
SEARCH_TERM=""
case "${1:-}" in
    add|list|show|open|remove|help|edit)
        OPERATION="$1"
        SEARCH_TERM="${2:-}"
        ;;
    "")
        echo "No search term provided" >&2
        exit 1
        ;;
    *)
        OPERATION="open"
        SEARCH_TERM="$1"
        ;;
esac

touch "$BM_FILE"

check_bookmarks() {
    if [ ! -s "$BM_FILE" ]; then
        echo "No bookmarks found" >&2
        exit 1
    fi
}

extract_url() {
    sed 's/.*](\([^)]*\)).*/\1/'
}

case "$OPERATION" in
help)
    echo "Usage: ,bm [command] [url]"
    echo ""
    echo "Commands:"
    echo "  add [url]  Add bookmark (url defaults to clipboard)"
    echo "  list       List all bookmarks"
    echo "  show       Fuzzy-pick bookmark(s), output URL(s) (default)"
    echo "  open       Fuzzy-pick bookmark(s), open in browser"
    echo "  remove     Fuzzy-pick bookmark(s) to remove"
    echo "  help       Show this help"
    ;;
add)
    url="${2:-$(pbpaste)}"
    if grep -F "($url)" "$BM_FILE" | glow; then
        echo "Bookmark already exists" >&2
        exit 1
    fi
    printf "Fetching title..."
    fetched_title="$(curl -sL "$url" | pup 'title text{}')"
    printf "\r\033[K"
    read -r -e -i "$fetched_title" -p "Title: " title
    printf "Tags (space-separated): "
    read -r tags
    tag_str=""
    if [ -n "$tags" ]; then
        for t in $tags; do
            tag_str="$tag_str #$t"
        done
    fi
    echo "- [$title]($url)$tag_str" >> "$BM_FILE"
    ;;
list)
    check_bookmarks
    if [ -n "$SEARCH_TERM" ]; then
        grep -i "$SEARCH_TERM" "$BM_FILE" | glow
    else
        glow "$BM_FILE"
    fi
    ;;
edit)
    $EDITOR "$BM_FILE"
    ;;
show)
    check_bookmarks
    cat "$BM_FILE" | ,picker -1 -i -m "$SEARCH_TERM" | extract_url
    ;;
open)
    check_bookmarks
    cat "$BM_FILE" | ,picker -1 -i -m "$SEARCH_TERM" | extract_url |
        while IFS= read -r url; do
            open "$url"
        done
    ;;
remove)
    check_bookmarks
    selected="$(cat "$BM_FILE" | ,picker -i -m "$SEARCH_TERM")"
    if [ -n "$selected" ]; then
        echo "$selected" | while IFS= read -r line; do
            grep -vF "$line" "$BM_FILE" > "$BM_FILE.tmp"
            mv "$BM_FILE.tmp" "$BM_FILE"
        done
    fi
    ;;
esac
