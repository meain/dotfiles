#!/bin/sh

set -e

rootdir="$(reporoot)"

flag=""
if [ "$1" = "-l" ]; then
    flag="-l"
    shift
fi

doc="$(find "$rootdir/.mdocs" -type f -name '*.md' -exec ls -t {} + |
    sed "s|$rootdir/.mdocs/||" |
    fzf -1 -m --query "$1" --preview "cat '$rootdir/.mdocs/{}'")"

echo ".mdocs/$doc"
,markdown-to-html $flag "$rootdir/.mdocs/$doc"
