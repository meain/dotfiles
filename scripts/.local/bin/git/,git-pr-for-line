#!/bin/sh

set -e

if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <file> <line>"
    exit 1
fi

if jj root >/dev/null 2>&1; then
    export GIT_DIR=$(jj git root)
    REPOURL=$(jj git remote list 2>/dev/null | awk '/^upstream / {print $2}')
    if [ -z "$REPOURL" ]; then
        REPOURL=$(jj git remote list 2>/dev/null | awk '/^origin / {print $2}')
    fi
else
    REPOURL=$(git remote get-url upstream 2>/dev/null || true)
    if [ -z "$REPOURL" ]; then
        REPOURL=$(git remote get-url origin)
    fi
fi

if [ -z "$REPOURL" ]; then
    echo "Could not determine repository"
    exit 1
fi

REPO=$(echo "$REPOURL" | cut -d: -f2 | sed 's/\.git$//')

URL="$(git blame -l -L "$2","$2" -s "$1" |
    cut -d' ' -f1 |
    xargs -I{} gh api "repos/$REPO/commits/{}/pulls" |
    jq -r '.[0].html_url')"

if [ "$URL" = "null" ]; then
    echo "No associated PR $2:$1"
    exit 1
fi

echo "$URL" | pbcopy
echo "$URL"
