#!/bin/sh
# Watch PRs in the merge queue and notify on merge or failure.
# Usage: ,gh-pr-watch [repo|pr-url]  (defaults to current repo)

set -e

INTERVAL=10 # seconds
arg="$1"

# Notify user
notter() {
	echo "$1"
	notify "PR Watch" "$1"
}

# pick a pr given a repo
pick_pr() {
	gh -R "$1" pr list --author '@me' --json number,title,mergeStateStatus,headRefName |
		jq -r '.[] | "\(.number) | \(.title) (\(.headRefName)"' |
		fzf -1 | cut -d' ' -f1
}

if [ -n "$arg" ]; then
	if echo "$arg" | grep -q 'github.com/[^/]*/[^/]*/pull/[^/]*'; then # pr url
		repo="$(echo "$arg" | sed 's|.*github.com/||;s|/pull/.*||')"
		pr="$(echo "$arg" | sed 's|.*github.com/.*/pull/||')"
	elif echo "$arg" | grep -q 'github.com/[^/]*/[^/]*$'; then # repo url
		repo="$(echo "$arg" | sed 's|.*github.com/||')"
		pr="$(pick_pr "$repo")"
	elif echo "$arg" | grep -q '^[^/]*/[^/]*$'; then # repo name
		repo="$arg"
		pr="$(pick_pr "$repo")"
	fi
else
	if jj status 2>/dev/null 1>/dev/null; then
		url="$(jj git remote list | grep origin | cut -d' ' -f2-)"
	else
		url="$(git remote get-url origin)"
	fi
	repo="$(echo "$url" | sed 's|git@github.com:||;s|\.git$||')"
	pr="$(pick_pr "$repo")"
fi

# Watch a pr given a repo and url name
watch_pr() {
	owner="$(echo "$1" | cut -d/ -f1)"
	repo="$(echo "$1" | cut -d/ -f2)"
	mergepos=""
	while true; do
		data="$(gh api graphql -f query='
{
  repository(owner: "'$owner'", name: "'$repo'") {
    pullRequest(number: '$2') {
      state
      mergedAt
      mergeQueueEntry {
        position
        state
        estimatedTimeToMerge
      }
    }
  }
}' | jq -c)"
		state="$(echo "$data" | jq -r .data.repository.pullRequest.state)"
		position="$(echo "$data" | jq -r .data.repository.pullRequest.mergeQueueEntry.position)"
		mstate="$(echo "$data" | jq -r .data.repository.pullRequest.mergeQueueEntry.state)"
		est="$(echo "$data" | jq -r .data.repository.pullRequest.mergeQueueEntry.estimatedTimeToMerge)"

		if [ "$mergepos" != "$position" ] && [ "$position" != "null" ]; then
			mergepos="$position"
			echo "$2: Awaiting merge (pos: $position, $(echo "$est"/60 | bc)m)"
		elif [ -n "$mergepos" ] && [ "$mstate" == "null" ]; then
			mergepos=""
			case "$state" in
			OPEN) notter "$2: Removed form mergequeue" ;;
			MERGED) notter "$2: Successfully merged" ;;
			CLOSED) notter "$2: PR closed" ;;
			esac
			return # stop watching
		else
			case "$state" in
			OPEN) echo "$2: PR open" ;;
			CLOSED) echo "$2: PR closed" ;;
			MERGED) notter "$2: Successfully merged" ;;
			esac

			if [ "$state" != "OPEN" ]; then
				return
			fi
		fi

		sleep $INTERVAL
	done
}

if [ -z "$pr" ]; then
	echo "No PR to watch"
	exit 1
fi

echo "Watching $repo/$pr"
watch_pr "$repo" "$pr" # currently only supports a single pr
