#!/bin/bash
# Watch PRs in the merge queue and notify on merge or failure.
# Usage: ,gh-pr-watch [repo|pr-url]  (defaults to current repo)

set -euo pipefail

INTERVAL=60
ARG="${1:-}"
REPO=""
DIRECT_PR=""

# Parse argument - could be repo, PR URL, or PR number
if [ -n "$ARG" ]; then
    if [[ "$ARG" =~ ^https://github\.com/([^/]+/[^/]+)/pull/([0-9]+) ]]; then
        # GitHub PR URL
        REPO="${BASH_REMATCH[1]}"
        DIRECT_PR="${BASH_REMATCH[2]}"
    elif [[ "$ARG" =~ ^[0-9]+$ ]]; then
        # Just a PR number
        DIRECT_PR="$ARG"
    else
        # Assume it's a repo slug
        REPO="$ARG"
    fi
fi

gh_cmd() {
    if [ -n "$REPO" ]; then
        gh "$@" -R "$REPO"
    else
        gh "$@"
    fi
}

queue_prs() {
    gh_cmd pr list \
        --author "@me" \
        --json number,title,mergeStateStatus,headRefName \
        --jq '.[] | select(.mergeStateStatus == "BLOCKED" or .mergeStateStatus == "CLEAN" or .mergeStateStatus == "HAS_HOOKS") | "\(.number)\t\(.title)\t[\(.headRefName)]"' \
        2>/dev/null
}

all_prs() {
    gh_cmd pr list \
        --author "@me" \
        --json number,title,headRefName \
        --jq '.[] | "\(.number)\t\(.title)\t[\(.headRefName)]"'
}

if [ -n "$DIRECT_PR" ]; then
    # Direct PR provided, use it
    pr_numbers="$DIRECT_PR"
else
    # Interactive selection
    prs="$(queue_prs)"
    [ -z "$prs" ] && prs="$(all_prs)"

    if [ -z "$prs" ]; then
        echo "No open PRs found"
        exit 0
    fi

    selected="$(echo "$prs" | column -t -s$'\t' | fzf -m --prompt="Select PRs to watch> ")"
    [ -z "$selected" ] && echo "No PR selected" && exit 0

    pr_numbers="$(echo "$selected" | awk '{print $1}')"
fi

echo "Watching PRs: $(echo "$pr_numbers" | tr '\n' ' ')"

done_prs=""

while true; do
    remaining=0
    for pr in $pr_numbers; do
        echo "$done_prs" | grep -qw "$pr" && continue
        remaining=$((remaining + 1))

        data="$(gh_cmd pr view "$pr" --json state,mergeStateStatus,title --jq '[.state, .mergeStateStatus, .title] | @tsv')"
        state="$(echo "$data" | cut -f1)"
        merge_status="$(echo "$data" | cut -f2)"
        title="$(echo "$data" | cut -f3)"

        echo "$(date '+%H:%M:%S') #$pr [$state/$merge_status] $title"

        if [ "$state" = "MERGED" ]; then
            notify "PR Merged ✅" "#$pr: $title"
            done_prs="$done_prs $pr"
            remaining=$((remaining - 1))
        elif [ "$state" = "CLOSED" ]; then
            notify --pri "PR Closed ❌" "#$pr closed without merging: $title"
            done_prs="$done_prs $pr"
            remaining=$((remaining - 1))
        elif [ "$merge_status" = "BLOCKED" ]; then
            notify --pri "PR Blocked ⚠️" "#$pr is blocked: $title"
        fi
    done

    [ "$remaining" -eq 0 ] && break

    sleep "$INTERVAL"
done

echo "All done."
