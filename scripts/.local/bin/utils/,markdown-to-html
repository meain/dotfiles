#!/bin/sh

# Convert markdown to html once. Use -l for live preview via ,markdown-preview.

set -e

live=0
if [ "$1" = "-l" ]; then
    live=1
    shift
fi

input="$1"
# if no file provided and interactive terminal, pick one with fzf
if [ -z "$input" ] && [ -t 0 ]; then
    input=$(fd -e md --max-depth 3 | fzf --preview 'head -50 {}') || exit 1
fi

if [ -d "$input" ]; then
    input="$input/$(fd -e md --max-depth 3 -C "$input" | fzf --preview "head -50 $input/{}")" || exit 1
fi

if [ ! -f "$input" ]; then
    echo "Not a file"
    exit 1
fi

# read from stdin if available
if [ -z "$input" ]; then
    if [ -t 0 ]; then
        echo "Usage: $0 [-l] <input.md> [output.html]"
        exit 1
    else
        input="/dev/stdin"
    fi
fi

if [ "$live" = 1 ]; then
    exec ,markdown-preview "$input"
fi

basename_noext=$(basename "$input" .md)
filename="/tmp/$(xxd -l2 -ps /dev/urandom)-${basename_noext}.html"
outfile=${2:-$filename}

cat "$DATAFILES_PATH/pandoc-github-template.html" >"$outfile"
awk 'NR==1 && /^---$/{skip=1; next} skip && /^---$/{skip=0; next} !skip' "$input" |
    pandoc --no-highlight \
    --template "$DATAFILES_PATH/pandoc-github-template.html" \
    --output - -f gfm -t html5 \
    --metadata title="$(basename "$input")" |
    perl -0777 -pe 's|<pre class="mermaid"><code>([^<]*)</code></pre>|<div class="mermaid">$1</div>|g' >"$outfile"
# we can safely use `<` in sed as pandoc will convert < in code to &le

[ -z "$NO_OPEN" ] && open "$outfile"
