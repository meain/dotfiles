#!/bin/sh

# Send notification

set -e

pri=0
to=5000
[ "$1" = "--pri" ] && shift && pri=1
[ "$1" = "-t" ] && shift && to="$1" && shift
if [ "$(uname)" = "Linux" ]; then
    if [ "$pri" = "1" ]; then
        notify-desktop --urgency=critical -t "$to" "${1:-Notification}" "${2}" >/dev/null 2>/dev/null
    else
        notify-desktop -t "$to" "${1:-Notification}" "${2}" >/dev/null 2>/dev/null
    fi
else
    if [ -n "$2" ]; then
        osascript -e 'on run argv' -e 'display notification (item 2 of argv) with title (item 1 of argv)' -e 'end run' -- "$1" "$2"
    else
        osascript -e 'on run argv' -e 'display notification (item 1 of argv) with title "Notification"' -e 'end run' -- "$1"
    fi
fi
