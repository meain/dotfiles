#!/bin/sh

set -e

CURRENT_PANE="$(tmux display-message -p -F "#{session_name}")"
if echo "$CURRENT_PANE" | grep -q '^popup.*'; then
    tmux detach-client
else
    case "$1" in
    "floater")
        tmux popup -d "$HOME" -w90% -h90% -E "tmux attach -t 'popup-floater' || tmux new -s 'popup-floater'" || true
        ;;
    "single")
        tmux popup -d "$HOME" -w90% -h90% -E "tmux attach -t 'popup-$CURRENT_PANE' || tmux new -s 'popup-$CURRENT_PANE'" || true
        ;;
    "companion")
        COMPANION_DIR="$HOME/dev/src/companion"
        tmux popup -d "$COMPANION_DIR" -x160% -y30% -w40% -h80% -E "tmux attach -t 'popup-companion' || tmux new-session -s 'popup-companion' -c $COMPANION_DIR claude" || true
        ;;
    "folder")
        # Get current folder path from tmux pane, defaulting to git root if available
        FOLDER="$(
            cd "$(tmux display-message -p "#{pane_current_path}")" &&
                reporoot 2>/dev/null ||
                tmux display-message -p "#{pane_current_path}"
        )"
        FOLDER_NAME="$(basename "$FOLDER")"
        tmux popup -d "$FOLDER" -x100% -y0% -w70% -h80% -E "tmux attach -t 'popup-$FOLDER_NAME' || tmux new -s 'popup-$FOLDER_NAME'" || true
        ;;
    *)
        tmux popup -x100% -y0% -w50% -h50% -E "tmux attach -t popup-master || tmux new -s popup-master" || true
        ;;
    esac
fi
