#!/bin/sh

set -e

tab=$(printf '\t')

selected=$(fin -sessions 2>/dev/null \
	| jq -r '.[] | "\(.id)\t\(.title) (\(.last_activity))"' \
	| ,picker -d "$tab" --with-nth 2 --preview 'fin -export message -session {1} 2>/dev/null | head -200')

if [ -z "$selected" ]; then
	exit 0
fi

session_id=$(echo "$selected" | cut -f1)

exec fin -session "$session_id" "$@"
