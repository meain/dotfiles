#!/bin/sh

set -e

agent=""
if [ -n "$1" ] && [ "$(echo "$1" | grep "^\+")" ]; then
    agent="$1"
    shift
fi

promptfile="$(ls $HOME/.config/datafiles/prompts/user |
    fzf -1 --query "$*" --preview "cat $HOME/.config/datafiles/prompts/user/{}")"
esa -- $agent "$(cat "$HOME/.config/datafiles/prompts/user/$promptfile")"
